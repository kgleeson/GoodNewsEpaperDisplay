# Copy to .env and fill in your secrets
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG=

# Display device (omni-epd device string)
# Use omni_epd.mock for local dev/testing without hardware
# Use waveshare_epd.epd7in3f for the Waveshare 7.3" 7-color display on Pi
EPAPER_DEVICE=omni_epd.mock

# AI models
# EPAPER_TEXT_MODEL=gpt-4o-mini
# EPAPER_IMAGE_MODEL=gpt-image-1
# EPAPER_IMAGE_SIZE=1536x1024

# Storage and scheduling
# EPAPER_DATA_DIR=/path/to/data
# EPAPER_SCHEDULE_HOUR=8
# EPAPER_SCHEDULE_MINUTE=0
# EPAPER_TIMEZONE=Europe/Dublin

# Web server
# EPAPER_WEB_HOST=0.0.0.0
# EPAPER_WEB_PORT=8000

# News feed
# EPAPER_RSS_FEED_URL=https://www.rte.ie/feeds/rss/?index=%2Fnews%2F

# Positivity filter tuning
# EPAPER_POSITIVITY_SAMPLE_SIZE=8
# EPAPER_POSITIVITY_SELECT_COUNT=3
